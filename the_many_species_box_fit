def nearest_impact_size(ant_count: int) -> int:
    keys = sorted(IMPACT_TEXTS.keys())
    return min(keys, key=lambda k: abs(k - ant_count))


def clamp(value: float, low: float, high: float) -> float:
    return max(low, min(high, value))


def season_modifier(season: str) -> float:
    table = {"spring": 1.04, "summer": 1.00, "autumn": 0.94, "fall": 0.94, "winter": 0.82, "wet": 1.03, "dry": 0.94}
    return table.get((season or "").lower().strip(), 1.00)


def temperature_modifier(temp_c: float, species: Dict) -> float:
    heat_tolerance = float(species["heat_tolerance"])
    if 22 <= temp_c <= 28:
        return 1.00
    if temp_c < 22:
        return clamp(1.00 - (22 - temp_c) * 0.018, 0.58, 1.00)
    penalty = (temp_c - 28) * (0.02 * (1.2 - heat_tolerance))
    return clamp(1.00 - penalty, 0.45, 1.00)


def humidity_modifier(humidity_percent: float) -> float:
    if 65 <= humidity_percent <= 90:
        return 1.00
    if humidity_percent < 65:
        return clamp(1.00 - (65 - humidity_percent) * 0.004, 0.72, 1.00)
    return clamp(1.00 - (humidity_percent - 90) * 0.003, 0.78, 1.00)


def rainfall_modifier(rainfall_mm: float, species: Dict) -> float:
    rain_tolerance = float(species["rain_tolerance"])
    if rainfall_mm <= 5:
        return 1.00
    if rainfall_mm <= 20:
        penalty = (rainfall_mm - 5) * 0.009 * (1.1 - rain_tolerance)
        return clamp(1.00 - penalty, 0.78, 1.00)
    penalty = 0.10 + (rainfall_mm - 20) * 0.010 * (1.2 - rain_tolerance)
    return clamp(1.00 - penalty, 0.38, 1.00)


def predator_modifier(predator_pressure: float) -> float:
    return clamp(1.00 - predator_pressure * 0.28, 0.62, 1.00)


def terrain_modifier(terrain_difficulty: float, species: Dict) -> float:
    obstacle_handling = float(species["obstacle_handling"])
    penalty = terrain_difficulty * (0.26 * (1.15 - obstacle_handling))
    return clamp(1.00 - penalty, 0.60, 1.00)


def food_abundance_modifier(food_abundance: float) -> float:
    return clamp(0.55 + 0.55 * food_abundance, 0.55, 1.10)


def fungus_health_modifier(fungus_health: float) -> float:
    return clamp(0.52 + 0.58 * fungus_health, 0.52, 1.10)


def colony_size_scaling(ant_count: int, species: Dict) -> float:
    reference_workers = float(species["reference_workers"])
    return (max(1.0, ant_count) / reference_workers) ** 0.93


def problem_penalty(name: str, severity: float, species: Dict) -> float:
    severity = clamp(float(severity), 0.0, 1.0)
    disease_resistance = float(species["disease_resistance"])
    rain_tolerance = float(species["rain_tolerance"])
    heat_tolerance = float(species["heat_tolerance"])
    name = name.lower().strip()
    if name in {"disease", "fungal infection", "parasite"}:
        return severity * (0.24 * (1.1 - disease_resistance))
    if name in {"predators", "predator attack"}:
        return severity * 0.18
    if name in {"flooding", "storm"}:
        return severity * (0.22 * (1.1 - rain_tolerance))
    if name in {"heatwave", "extreme heat"}:
        return severity * (0.25 * (1.1 - heat_tolerance))
    if name in {"rough terrain", "fallen branches", "obstacles"}:
        return severity * 0.16
    if name in {"human disturbance", "pesticides", "human"}:
        return severity * 0.26
    if name in {"competition"}:
        return severity * 0.14
    return severity * 0.15


def problem_modifier(problem_map: Dict[str, float], species: Dict) -> float:
    modifier = 1.0
    for name, severity in problem_map.items():
        modifier *= (1.0 - problem_penalty(name, severity, species))
    return clamp(modifier, 0.25, 1.00)


def simulate_leaf_gathering(payload: Dict) -> Dict:
    ant_count = int(payload.get("antCount", 0))
    species_key = str(payload.get("speciesKey", "atta_colombica"))
    if ant_count <= 0:
        raise ValueError("antCount must be greater than 0")
    if species_key not in SPECIES_DB:
        raise ValueError("Unknown speciesKey")

    species = SPECIES_DB[species_key]
    problems = {
        "disease": float(payload.get("diseaseSeverity", 0)),
        "storm": float(payload.get("stormSeverity", 0)),
        "heatwave": float(payload.get("heatwaveSeverity", 0)),
        "human": float(payload.get("humanSeverity", 0)),
        "competition": float(payload.get("competitionSeverity", 0)),
    }

    modifiers = {
        "season": season_modifier(str(payload.get("season", "summer"))),
        "temperature": temperature_modifier(float(payload.get("temperature", 27)), species),
        "humidity": humidity_modifier(float(payload.get("humidity", 78))),
        "rainfall": rainfall_modifier(float(payload.get("rainfall", 12)), species),
        "predators": predator_modifier(float(payload.get("predatorPressure", 0.30))),
        "terrain": terrain_modifier(float(payload.get("terrainDifficulty", 0.40)), species),
        "food_abundance": food_abundance_modifier(float(payload.get("foodAbundance", 0.85))),
        "fungus_health": fungus_health_modifier(float(payload.get("fungusHealth", 0.90))),
        "problems": problem_modifier(problems, species),
    }

    environment_modifier = 1.0
    for value in modifiers.values():
        environment_modifier *= value
    environment_modifier = clamp(environment_modifier, 0.08, 2.25)

    colony_scaling = colony_size_scaling(ant_count, species)
    estimated_leaf_area_m2_day = float(species["harvest_area_m2_day_reference"]) * colony_scaling * environment_modifier
    matched = nearest_impact_size(ant_count)

    return {
        "speciesKey": species_key,
        "species": species["name"],
        "genus": species["genus"],
        "antCount": ant_count,
        "referenceWorkers": int(species["reference_workers"]),
        "harvestBasis": species["harvest_basis"],
        "scientificNote": species["scientific_note"],
        "substrateNote": species["substrate_note"],
        "colonyScaling": round(colony_scaling, 4),
        "environmentModifier": round(environment_modifier, 4),
        "estimatedLeafAreaM2PerDay": round(estimated_leaf_area_m2_day, 3),
        "estimatedLeafAreaCm2PerDay": round(estimated_leaf_area_m2_day * 10000.0, 0),
        "breakdown": {k: round(v, 4) for k, v in modifiers.items()},
        "impactClosestCount": matched,
        "impactNarrative": IMPACT_TEXTS[matched],
        "inputs": payload,
    }


def simulate_over_time(payload: Dict, days: int) -> List[Dict]:
    days = max(1, min(int(days), 365))
    base_date = datetime.now().date()
    results = []
    for i in range(days):
        varied = dict(payload)
        season = str(payload.get("season", "summer")).lower().strip()
        temp_shift = math.sin(i / 4.0) * 1.2
        rain_shift = max(0, math.cos(i / 3.2) * 2.4)
        food_shift = math.sin(i / 8.0) * 0.04
        fungus_shift = math.cos(i / 10.0) * 0.03
        if season == "winter":
            temp_shift -= 2.2
        elif season == "summer":
            temp_shift += 1.2
        elif season == "wet":
            rain_shift += 3.5
        elif season == "dry":
            rain_shift = max(0, rain_shift - 1.3)
        varied["temperature"] = round(float(payload.get("temperature", 27)) + temp_shift, 2)
        varied["rainfall"] = round(max(0, float(payload.get("rainfall", 12)) + rain_shift), 2)
        varied["foodAbundance"] = round(clamp(float(payload.get("foodAbundance", 0.85)) + food_shift, 0, 1), 3)
        varied["fungusHealth"] = round(clamp(float(payload.get("fungusHealth", 0.90)) + fungus_shift, 0, 1), 3)
        sim = simulate_leaf_gathering(varied)
        results.append({
            "date": (base_date + timedelta(days=i)).isoformat(),
            "leaf_area_m2_day": sim["estimatedLeafAreaM2PerDay"],
            "temperature_c": varied["temperature"],
            "rainfall_mm": varied["rainfall"],
        })
    return results


