<body>
<div class=\"wrap\">
  {% with messages = get_flashed_messages() %}{% if messages %}{% for message in messages %}<div class=\"flash\">{{ message }}</div>{% endfor %}{% endif %}{% endwith %}
  <div class=\"tele-head\"><h1>The Many</h1></div>
  <div class=\"grid\">
    <div class=\"stack\">
      <div class=\"card\">
        <h2>Run Calculator</h2>
        <div class=\"section-grid\">
          <div><label>Scenario Name</label><input id=\"scenarioName\" value=\"Field Scenario 1\" /></div>
          <div><label>Climate Preset</label><select id=\"presetSelect\" onchange=\"applyPreset()\"><option value=\"\">Custom</option></select></div>
          <div><label>Leafcutter Species</label><select id=\"speciesKey\"></select></div>
          <div><label>Season</label><select id=\"season\"><option value=\"spring\">Spring</option><option value=\"summer\">Summer</option><option value=\"autumn\">Autumn</option><option value=\"winter\">Winter</option><option value=\"wet\">Wet</option><option value=\"dry\">Dry</option></select></div>
          <div><label>Colony Size (workers)</label><input type=\"number\" id=\"antCount\" value=\"2000000\" min=\"1\" /></div>
          <div><label>Temperature (°C)</label><input type=\"number\" id=\"temperature\" value=\"27\" step=\"0.1\" /></div>
          <div><label>Humidity (%)</label><input type=\"number\" id=\"humidity\" value=\"78\" step=\"0.1\" min=\"0\" max=\"100\" /></div>
          <div><label>Rainfall (mm/day)</label><input type=\"number\" id=\"rainfall\" value=\"12\" step=\"0.1\" min=\"0\" /></div>
          <div><label>Predator Pressure (0–1)</label><input type=\"number\" id=\"predatorPressure\" value=\"0.30\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Terrain Difficulty (0–1)</label><input type=\"number\" id=\"terrainDifficulty\" value=\"0.40\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Food Abundance (0–1)</label><input type=\"number\" id=\"foodAbundance\" value=\"0.85\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Fungus Health (0–1)</label><input type=\"number\" id=\"fungusHealth\" value=\"0.90\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Disease Severity (0–1)</label><input type=\"number\" id=\"diseaseSeverity\" value=\"0.10\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Storm Severity (0–1)</label><input type=\"number\" id=\"stormSeverity\" value=\"0.00\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Heatwave Severity (0–1)</label><input type=\"number\" id=\"heatwaveSeverity\" value=\"0.00\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Human Disturbance (0–1)</label><input type=\"number\" id=\"humanSeverity\" value=\"0.00\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Competition Severity (0–1)</label><input type=\"number\" id=\"competitionSeverity\" value=\"0.00\" step=\"0.01\" min=\"0\" max=\"1\" /></div>
          <div><label>Time-Series Days</label><input type=\"number\" id=\"days\" value=\"30\" min=\"1\" max=\"365\" /></div>
        </div>
        <div class=\"btn-row\"><button onclick=\"runSimulation()\">Calculate</button><button onclick=\"addComparison()\">Add To Comparison</button><button onclick=\"downloadCurrentCSV()\">Export Current CSV</button></div>
      </div>
      <div class=\"card\">
        <h2>Results</h2>
        <div class=\"metrics\" id=\"metrics\"></div>
        <div class=\"scientific-box\" id=\"scientificBox\" style=\"display:none;\"></div>
        <div class=\"impact-box\" id=\"impactBox\" style=\"display:none;\"></div>
        <h2 style=\"margin-top:18px;\">Modifier Breakdown</h2>
        <table><thead><tr><th>Factor</th><th>Modifier (unitless)</th></tr></thead><tbody id=\"breakdownBody\"></tbody></table>
      </div>
      <div class=\"card\"><h2>Harvest Through Time</h2><div class=\"small\">Axis labels include units and extra padding so the numbers do not get cut off.</div><div class=\"chart-wrap\" style=\"margin-top:12px;\"><canvas id=\"timeChart\"></canvas></div></div>
      <div class=\"card\"><h2>Species Comparison</h2><table><thead><tr><th>Name</th><th>Species</th><th>Colony Size</th><th>Leaf Harvest</th><th>Reference Colony</th><th>Environment Modifier</th></tr></thead><tbody id=\"comparisonBody\"></tbody></table><div class=\"chart-wrap\" style=\"margin-top:16px;\"><canvas id=\"comparisonChart\"></canvas></div></div>
    </div>
    <div class=\"stack\">
      <div class=\"card\"><h2>Scientific Basis</h2><ul class=\"notes\"><li>Primary output is estimated leaf area harvested per day in <strong>m²/day</strong>.</li><li><strong>Atta colombica</strong> is anchored to a field baseline around <strong>9.0–11.4 m²/day</strong>, represented here with a midpoint of <strong>10.2 m²/day</strong>.</li><li>Cross-species comparison uses worker-number scaling close to exponent <strong>0.93</strong>.</li><li><strong>Atta</strong> species generally forage more from trees, while <strong>Acromyrmex</strong> species more often use herbaceous leaves and flowers.</li><li>This is a research-based estimate, not a full field ecology model.</li></ul></div>
      <div class=\"card\"><h2>Preset Notes</h2><ul class=\"notes\"><li>Amazon Wet Forest: high humidity, strong food availability, heavier rainfall.</li><li>Dry Tropical Forest: hotter, drier, stronger heat stress.</li><li>Montane Forest: cooler and harder terrain.</li><li>Disturbed Farmland Edge: decent food but more human disturbance.</li><li>Urban Garden Patch: easier terrain but frequent human pressure.</li></ul></div><div class=\"card\"><h2>Leafcutter Subspecies</h2><table class=\"species-table\"><thead><tr><th>Name</th><th>Genus</th><th>Reference Colony</th><th>Harvest Basis</th><th>Substrate</th><th>Scientific Note</th></tr></thead><tbody id=\"speciesInfoBody\"></tbody></table></div>
    </div>
  </div>
</div>
<script>
const CLIMATE_PRESETS = {{ presets_json|safe }};
const SPECIES_DB = {{ species_json|safe }};
let currentResult = null, currentTimeSeries = [], comparisonScenarios = [], timeChart = null, comparisonChart = null;
const byId = (id) => document.getElementById(id);
function populateStaticOptions(){const presetSelect = byId("presetSelect"); Object.entries(CLIMATE_PRESETS).forEach(([k,v])=>{const o=document.createElement("option");o.value=k;o.textContent=v.label;presetSelect.appendChild(o);}); const speciesSelect = byId("speciesKey"); Object.entries(SPECIES_DB).forEach(([k,v])=>{const o=document.createElement("option");o.value=k;o.textContent=v.name;speciesSelect.appendChild(o);});}function populateSpeciesInfo(){const body=byId("speciesInfoBody");if(!body)return;body.innerHTML="";Object.entries(SPECIES_DB).forEach(([k,v])=>{const row=document.createElement("tr");row.innerHTML=`<td>${v.name}</td><td>${v.genus}</td><td>${Number(v.reference_workers).toLocaleString()} workers</td><td>${v.harvest_basis}</td><td>${v.substrate_note}</td><td><div class="species-note">${v.scientific_note}</div></td>`;body.appendChild(row);});}
function applyPreset(){const key=byId("presetSelect").value;if(!key)return;const p=CLIMATE_PRESETS[key];byId("temperature").value=p.temperature;byId("humidity").value=p.humidity;byId("rainfall").value=p.rainfall;byId("predatorPressure").value=p.predatorPressure;byId("terrainDifficulty").value=p.terrainDifficulty;byId("foodAbundance").value=p.foodAbundance;byId("fungusHealth").value=p.fungusHealth;byId("season").value=p.season;byId("stormSeverity").value=p.stormSeverity;byId("heatwaveSeverity").value=p.heatwaveSeverity;byId("diseaseSeverity").value=p.diseaseSeverity;byId("humanSeverity").value=p.humanSeverity;byId("competitionSeverity").value=p.competitionSeverity;byId("scenarioName").value=p.label;}
function formPayload(){return {scenarioName:byId("scenarioName").value.trim()||"Untitled Scenario",speciesKey:byId("speciesKey").value,antCount:Number(byId("antCount").value),season:byId("season").value,temperature:Number(byId("temperature").value),humidity:Number(byId("humidity").value),rainfall:Number(byId("rainfall").value),predatorPressure:Number(byId("predatorPressure").value),terrainDifficulty:Number(byId("terrainDifficulty").value),foodAbundance:Number(byId("foodAbundance").value),fungusHealth:Number(byId("fungusHealth").value),diseaseSeverity:Number(byId("diseaseSeverity").value),stormSeverity:Number(byId("stormSeverity").value),heatwaveSeverity:Number(byId("heatwaveSeverity").value),humanSeverity:Number(byId("humanSeverity").value),competitionSeverity:Number(byId("competitionSeverity").value),days:Number(byId("days").value)};}
async function runSimulation(){const res=await fetch("/api/simulate",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(formPayload())});const data=await res.json();if(!res.ok)return alert(data.error||"Unable to run simulation.");currentResult=data.result;currentTimeSeries=data.timeSeries;renderResults();renderTimeChart();}
function renderResults(){const metrics=byId("metrics");metrics.innerHTML="";const entries=[["Scenario",currentResult.inputs.scenarioName||"Untitled"],["Species",currentResult.species],["Colony Size",Number(currentResult.antCount).toLocaleString()+" workers"],["Reference Colony",Number(currentResult.referenceWorkers).toLocaleString()+" workers"],["Leaf Harvest",Number(currentResult.estimatedLeafAreaM2PerDay).toFixed(3)+" m²/day"],["Leaf Harvest",Number(currentResult.estimatedLeafAreaCm2PerDay).toLocaleString()+" cm²/day"],["Environment Modifier",currentResult.environmentModifier+" unitless"],["Colony Scaling",currentResult.colonyScaling+" unitless"]]; entries.forEach(([l,v])=>{const d=document.createElement("div");d.className="metric";d.innerHTML=`<div class="label">${l}</div><div class="value">${v}</div>`;metrics.appendChild(d);}); const box=byId("scientificBox");box.style.display="block";box.innerHTML=`<div><strong>Harvest basis:</strong> ${currentResult.harvestBasis}</div><div style="margin-top:6px;"><strong>Substrate note:</strong> ${currentResult.substrateNote}</div><div style="margin-top:6px;"><strong>Scientific note:</strong> ${currentResult.scientificNote}</div>`; const impact=byId("impactBox");impact.style.display="block";impact.innerHTML=`<h3>Closest ecological narrative: ${Number(currentResult.impactClosestCount).toLocaleString()} ants</h3><div>${currentResult.impactNarrative}</div>`; const body=byId("breakdownBody");body.innerHTML="";Object.entries(currentResult.breakdown).forEach(([k,v])=>{const r=document.createElement("tr");r.innerHTML=`<td>${k.replaceAll("_"," ")}</td><td>${Number(v).toFixed(4)}</td>`;body.appendChild(r);});}
function baseChartOptions(yTitle){return {responsive:true,maintainAspectRatio:false,layout:{padding:{left:34,right:18,top:10,bottom:18}},plugins:{legend:{labels:{color:"#f5f5f5",padding:16,font:{family:"Courier New",size:12}}}},scales:{x:{ticks:{color:"#9fdfff",maxRotation:45,minRotation:45,autoSkip:true,padding:8,font:{family:"Courier New",size:11}},grid:{color:"rgba(0,199,255,.25)"}},y:{title:{display:true,text:yTitle,color:"#ffe100",font:{family:"Arial",size:12,weight:"bold"}},ticks:{color:"#9fdfff",padding:10,font:{family:"Courier New",size:11}},grid:{color:"rgba(0,199,255,.25)"}}}};}
function renderTimeChart(){const ctx=byId("timeChart").getContext("2d");if(timeChart)timeChart.destroy();timeChart=new Chart(ctx,{type:"line",data:{labels:currentTimeSeries.map(x=>x.date),datasets:[{label:"Leaf harvest (m²/day)",data:currentTimeSeries.map(x=>x.leaf_area_m2_day),borderColor:"#ffe100",backgroundColor:"rgba(255,225,0,.12)",pointRadius:3,pointHoverRadius:4,tension:0.25}]},options:{...baseChartOptions("Leaf harvest (m²/day)"),scales:{...baseChartOptions("Leaf harvest (m²/day)").scales,y:{...baseChartOptions("Leaf harvest (m²/day)").scales.y,grace:"6%",ticks:{color:"#9fdfff",padding:10,font:{family:"Courier New",size:11},callback:function(value){return Number(value).toFixed(1)+" m²";}}}}}});}
function addComparison(){if(!currentResult)return alert("Run a simulation first.");comparisonScenarios.push({name:currentResult.inputs.scenarioName||"Untitled",species:currentResult.species,ants:currentResult.antCount,harvested:currentResult.estimatedLeafAreaM2PerDay,referenceWorkers:currentResult.referenceWorkers,modifier:currentResult.environmentModifier});renderComparisonTable();renderComparisonChart();}
function renderComparisonTable(){const body=byId("comparisonBody");body.innerHTML="";comparisonScenarios.forEach(item=>{const r=document.createElement("tr");r.innerHTML=`<td>${item.name}</td><td>${item.species}</td><td>${Number(item.ants).toLocaleString()} workers</td><td>${Number(item.harvested).toFixed(3)} m²/day</td><td>${Number(item.referenceWorkers).toLocaleString()} workers</td><td>${item.modifier} unitless</td>`;body.appendChild(r);});}
function renderComparisonChart(){const ctx=byId("comparisonChart").getContext("2d");if(comparisonChart)comparisonChart.destroy();comparisonChart=new Chart(ctx,{type:"bar",data:{labels:comparisonScenarios.map(x=>x.name),datasets:[{label:"Leaf harvest (m²/day)",data:comparisonScenarios.map(x=>x.harvested),backgroundColor:"#ff38a5",borderColor:"#ffe100",borderWidth:1}]},options:{...baseChartOptions("Leaf harvest (m²/day)"),scales:{...baseChartOptions("Leaf harvest (m²/day)").scales,y:{...baseChartOptions("Leaf harvest (m²/day)").scales.y,grace:"8%",ticks:{color:"#9fdfff",padding:10,font:{family:"Courier New",size:11},callback:function(value){return Number(value).toFixed(1)+" m²";}}}}}});}
function downloadCurrentCSV(){if(!currentResult)return alert("Run a simulation first.");window.location.href=`/export_current_csv?payload=${encodeURIComponent(JSON.stringify(formPayload()))}`;}
populateStaticOptions();populateSpeciesInfo();
</script>
</body>
</html>
"""

@app.route("/")
def index():
    return render_template_string(PAGE_TEMPLATE, presets_json=json.dumps(CLIMATE_PRESETS), species_json=json.dumps(SPECIES_DB))

@app.route("/api/simulate", methods=["POST"])
def api_simulate():
    try:
        payload = request.get_json(force=True) or {}
        return jsonify({"result": simulate_leaf_gathering(payload), "timeSeries": simulate_over_time(payload, int(payload.get("days", 30)))})
    except Exception as e:
        return jsonify({"error": str(e)}), 400


def payload_to_csv_bytes(payload: Dict) -> bytes:
    result = simulate_leaf_gathering(payload)
    time_series = simulate_over_time(payload, int(payload.get("days", 30)))
    out = io.StringIO()
    writer = csv.writer(out)
    writer.writerow(["Scenario Summary"])
    writer.writerow(["Scenario Name", payload.get("scenarioName", "Untitled Scenario")])
    writer.writerow(["Species", result["species"]])
    writer.writerow(["Colony Size (workers)", result["antCount"]])
    writer.writerow(["Reference Colony Size (workers)", result["referenceWorkers"]])
    writer.writerow(["Estimated Leaf Harvest (m2/day)", result["estimatedLeafAreaM2PerDay"]])
    writer.writerow(["Estimated Leaf Harvest (cm2/day)", result["estimatedLeafAreaCm2PerDay"]])
    writer.writerow(["Environment Modifier (unitless)", result["environmentModifier"]])
    writer.writerow(["Colony Scaling (unitless)", result["colonyScaling"]])
    writer.writerow(["Impact Narrative Closest Count", result["impactClosestCount"]])
    writer.writerow(["Harvest Basis", result["harvestBasis"]])
    writer.writerow(["Substrate Note", result["substrateNote"]])
    writer.writerow(["Scientific Note", result["scientificNote"]])
    writer.writerow([])
    writer.writerow(["Inputs"])
    for k, v in payload.items():
        writer.writerow([k, v])
    writer.writerow([])
    writer.writerow(["Breakdown"])
    for k, v in result["breakdown"].items():
        writer.writerow([k, v])
    writer.writerow([])
    writer.writerow(["Time Series"])
    writer.writerow(["date", "leaf_area_m2_day", "temperature_c", "rainfall_mm"])
    for row in time_series:
        writer.writerow([row["date"], row["leaf_area_m2_day"], row["temperature_c"], row["rainfall_mm"]])
    return out.getvalue().encode("utf-8")

@app.route("/export_current_csv")
def export_current_csv():
    payload_str = request.args.get("payload", "")
    if not payload_str:
        flash("No scenario payload provided.")
        return redirect(url_for("index"))
    try:
        payload = json.loads(payload_str)
    except json.JSONDecodeError:
        flash("Invalid scenario payload.")
        return redirect(url_for("index"))
    data = payload_to_csv_bytes(payload)
    name = (payload.get("scenarioName") or "scenario").replace(" ", "_")
    return send_file(io.BytesIO(data), mimetype="text/csv", as_attachment=True, download_name=f"{name}.csv")

@app.route("/health")
def health():
    return Response("ok", mimetype="text/plain")

if __name__ == "__main__":
    app.run()
